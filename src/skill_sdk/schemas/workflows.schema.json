{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow Definitions Schema",
  "description": "Schema for workflows.yaml in a skill directory",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "name", "description", "states", "transitions", "required"],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1,
        "description": "Unique workflow identifier"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Workflow name"
      },
      "description": {
        "type": "string",
        "minLength": 1,
        "description": "Description of the workflow's purpose"
      },
      "states": {
        "type": "array",
        "minItems": 2,
        "items": {
          "type": "object",
          "required": ["id", "name", "description"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "initial": {
              "type": "boolean",
              "default": false
            },
            "terminal": {
              "type": "boolean",
              "default": false
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "transitions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["from", "to"],
          "properties": {
            "from": {
              "type": "string",
              "minLength": 1
            },
            "to": {
              "type": "string",
              "minLength": 1
            },
            "condition": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "evidence_requirements": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": {
        "type": "boolean",
        "default": true
      }
    },
    "additionalProperties": false
  }
}