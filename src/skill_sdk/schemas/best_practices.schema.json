{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Best Practices Schema",
  "description": "Schema for best_practices.yaml in a skill directory",
  "oneOf": [
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  ]
}